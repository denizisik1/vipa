   <string>QMainWindow {
    background-color: #b8b8b8;
    color: #1e1e1e;
}
QTabWidget::pane {
    border: 1px solid #8a8a8a;
    background-color: #c4c4c4;
}
QTabBar::tab {
    background-color: #b0b0b0;
    color: #1e1e1e;
    padding: 4px 10px;
}
QTabBar::tab:selected { background-color: #9a9a9a; }
QTabBar::tab:hover { background-color: #a8a8a8; }
QWidget { background-color: #c4c4c4; color: #1e1e1e; }
QLabel { color: #1e1e1e; }
QLineEdit, QTextEdit, QComboBox, QSpinBox {
    background-color: #e0e0e0;
    color: #1e1e1e;
    border: 1px solid #8a8a8a;
    border-radius: 2px;
    padding: 2px 4px;
}
QLineEdit:focus, QTextEdit:focus, QComboBox:focus, QSpinBox:focus {
    border: 1px solid #0078d4;
}
QPushButton {
    background-color: #0078d4;
    color: #ffffff;
    border: none;
    border-radius: 2px;
    padding: 4px 8px;
}
QPushButton:hover { background-color: #106ebe; }
QPushButton:pressed { background-color: #005a9e; }
QStatusBar { background-color: #a8a8a8; color: #1e1e1e; }
QGroupBox {
    border: 1px solid #8a8a8a;
    border-radius: 3px;
    margin-top: 6px;
    padding: 6px 4px 4px 4px;
    font-weight: 600;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 8px;
    padding: 0 4px;
}
QProgressBar {
    border: 1px solid #8a8a8a;
    border-radius: 2px;
    text-align: center;
    background-color: #e0e0e0;
    max-height: 18px;
    color: #1e1e1e;
}
QProgressBar::chunk { background-color: #0078d4; border-radius: 2px; }
QSlider::groove:horizontal { height: 4px; background: #e0e0e0; border-radius: 2px; }
QSlider::handle:horizontal { width: 12px; margin: -4px 0; background: #0078d4; border-radius: 6px; }
QLabel#label_6 { color: #555555; font-style: italic; }</string>
