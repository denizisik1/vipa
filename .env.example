# Vocabulary path overrides (leave empty to use built-in defaults)
VIPA_VOCABULARY_DIR=
VIPA_USER_VOCABULARY_DIR=

# HTTP fetch
VIPA_HTTP_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
VIPA_HTTP_ACCEPT=text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8
VIPA_HTTP_ACCEPT_LANGUAGE=en-US,en;q=0.9
VIPA_FETCH_TIMEOUT_SECONDS=20
VIPA_PROBE_TIMEOUT_SECONDS=10
VIPA_PLAYWRIGHT_EXTRA_TIMEOUT_SECONDS=10

# IPA sources (Sources tab defaults)
VIPA_PRIMARY_SOURCE_URL=https://www.collinsdictionary.com/dictionary/german-english/
VIPA_PRIMARY_FIND_BY=pron
VIPA_BACKUP_SOURCE_URL=https://en.pons.com/translate/german-english/
VIPA_BACKUP_FIND_BY=phonetics
VIPA_SAMPLE_WORD=Abend

# Notifications and UI timing
VIPA_NOTIFY_EXPIRE_MS=10000
VIPA_RETRIEVE_FLASH_MS=1200

# App defaults when no user config file exists
VIPA_DEFAULT_LANGUAGE=german
VIPA_DEFAULT_THEME=white
VIPA_DEFAULT_ZOOM_PERCENT=100
VIPA_DEFAULT_DAEMON_INTERVAL_MINUTES=15
VIPA_DEFAULT_NOTIFY_BACKEND=desktop
VIPA_DEFAULT_WINDOW_WIDTH=720
VIPA_DEFAULT_WINDOW_HEIGHT=560
VIPA_MIN_WINDOW_WIDTH=560
VIPA_MIN_WINDOW_HEIGHT=420
